        Array("notifications_cdmsmith@engage.mail.microsoft", "From CDM\From Viva Engage"), _
        Array("noreply_cdmsmith@engage.mail.microsoft", "From CDM\From Viva Engage"), _
        Array("MarComm-disp@cdmsmith.com", "From CDM\From Marketing and Communications"), _
        Array("mentorship@togetherplatform.com", "From CDM\From Career Compass"), _
        Array("ITHelp@cdmsmith.com", "From CDM\From IT"), _
        Array("HR-Communications@cdmsmith.com", "From CDM\From HR") _
    )
    
    '-----------------------------
    ' Define subject-based rules
    '-----------------------------
    ' Currently placeholder; same format as SenderRules
    SubjectRules = Array( _
        Array("Target Subject 1", "Target Folder 1"), _
        Array("Target Subject 2", "Target Folder 2") _
    )

End Sub

'===========================================================
' NEW: Setup Daily Task (The "Timer" Replacement)
'===========================================================
Sub SetupDailyTask()
    Dim taskItem As Outlook.taskItem
    Dim folder As Outlook.folder
    Dim ns As Outlook.NameSpace
    
    Set ns = Application.GetNamespace("MAPI")
    Set folder = ns.GetDefaultFolder(olFolderTasks)
    
    ' Look for existing monitor task
    On Error Resume Next
    Set taskItem = folder.Items("Email Summary Monitor")
    On Error GoTo 0
    
    ' Create it if it doesn't exist
    If taskItem Is Nothing Then
        Set taskItem = Application.CreateItem(olTaskItem)
        taskItem.Subject = "Email Summary Monitor"
    End If
    
    ' Set the reminder for 3:15 PM
    taskItem.ReminderSet = True
    taskItem.ReminderTime = DateValue(Now) & " 16:30:00"
    
    ' If it's already past 3:15 PM today, move it to tomorrow
    If taskItem.ReminderTime < Now Then
        taskItem.ReminderTime = DateAdd("d", 1, taskItem.ReminderTime)
    End If
    
    taskItem.Save
    Debug.Print "Daily Summary successfully scheduled for: " & taskItem.ReminderTime
End Sub


'=============================
' Process Incoming Emails
'=============================
Sub ProcessMail(mail As Outlook.MailItem)

    Dim i As Long
    Dim senderAddress As String
    Dim exchUser As Outlook.ExchangeUser
    
    ' Initialize rules if needed
    If IsEmpty(SenderRules) Then InitializeRules
     
    '-----------------------------
    ' Get sender email
    ' Handle Exchange internal addresses (EX type)
    '-----------------------------
    senderAddress = mail.SenderEmailAddress
    
    If mail.SenderEmailType = "EX" Then
        Set exchUser = mail.Sender.GetExchangeUser
        If Not exchUser Is Nothing Then
            senderAddress = exchUser.PrimarySmtpAddress
        End If
    End If
    
    Debug.Print senderAddress
    
    '-----------------------------
    ' Check against sender rules
    '-----------------------------
    For i = LBound(SenderRules) To UBound(SenderRules)
        Debug.Print mail.SenderEmailAddress
        If LCase(senderAddress) = LCase(SenderRules(i)(0)) Then
        
            MoveEmail mail, SenderRules(i)(1)
            Exit Sub
            
        End If
        
    Next i
    
    '-------------------------------------
    ' Apply subject rules (optional)
    ' This might get removed if never used
    '-------------------------------------
    For i = LBound(SubjectRules) To UBound(SubjectRules)
        Debug.Print mail.SenderEmailAddress
        If InStr(1, mail.Subject, SubjectRules(i)(0), vbTextCompare) > 0 Then
        
            MoveEmail mail, SubjectRules(i)(1)
            Exit Sub
            
        End If
        
    Next i

End Sub

'=============================
' Move Email to Target Folder
'=============================

Sub MoveEmail(mail As Outlook.MailItem, ByVal FolderPath As String)

    Dim ns As Outlook.NameSpace
    Dim rootFolder As Outlook.folder
    Dim targetFolder As Outlook.folder
    Dim folderNames() As String
    Dim i As Long
    Dim nextFolder As Outlook.folder
    Dim logEntry As String
    
    '-----------------------------
    ' Root folder reference
    ' If the target folder is a parent-level folder outside Inbox, this handles it
    '-----------------------------
    Set ns = Application.GetNamespace("MAPI")
    Set rootFolder = ns.folders(mail.Parent.Parent.Name)
    
    ' Split path to handle nested folders
    folderNames = Split(FolderPath, "\")
    Set targetFolder = rootFolder
    
    ' Loop through folder path; create folders if they don't exist
    For i = LBound(folderNames) To UBound(folderNames)
    
        Set nextFolder = Nothing
        
        On Error Resume Next
        Set nextFolder = targetFolder.folders(folderNames(i))
        On Error GoTo 0
        
        If nextFolder Is Nothing Then
            Set nextFolder = targetFolder.folders.Add(folderNames(i))
        End If
        
        Set targetFolder = nextFolder
        
    Next i
    
     '-----------------------------
    ' Log moved email
    '-----------------------------
    If MovedEmails Is Nothing Then Set MovedEmails = New Collection
    Dim cleanSender As String
    cleanSender = mail.SenderEmailAddress

    ' If Exchange sender, get primary SMTP
    If mail.SenderEmailType = "EX" Then
        Dim exchUser As Outlook.ExchangeUser
        Set exchUser = mail.Sender.GetExchangeUser
        If Not exchUser Is Nothing Then
            cleanSender = exchUser.PrimarySmtpAddress
        Else
            ' Fallback for automated email (like the daily summary)
            cleanSender = "Self Generated"
        End If
    End If
    
    ' Format log entry: Time | Sender | Subject | Target Folder
    logEntry = Format(Now, "hh:mm AM/PM") & " | " & cleanSender & " | " & mail.Subject & " | " & FolderPath
    MovedEmails.Add logEntry
    
    ' Move the email to the target folder
    mail.Move targetFolder

    Debug.Print "Moving: " & mail.Subject & " ? " & FolderPath
    

End Sub

'=============================
' Send Daily Summary Email
'=============================
Sub SendDailySummary()

    Dim outMail As Outlook.MailItem
    Dim item As Variant
    Dim bodyText As String
    
    
    ' 1. Check if the collection even exists first
    If MovedEmails Is Nothing Then
        Debug.Print "No emails moved today (Collection is Nothing)."
        Exit Sub
    End If
    
    ' 2. If it exists, check if it's empty
    If MovedEmails.Count = 0 Then
        Debug.Print "No emails moved today (Count is 0)."
        Exit Sub
    End If
    
    Set outMail = Application.CreateItem(olMailItem)
    
    bodyText = "Daily Email Automation Summary" & vbCrLf & vbCrLf
    
    For Each item In MovedEmails
        bodyText = bodyText & item & vbCrLf
    Next item
    
    
    ' Build email body
    bodyText = bodyText & vbCrLf & "Total moved today: " & MovedEmails.Count
    
    ' Send the email
    With outMail
        .To = "hyresdf@cdmsmith.com" ' your email
        .Subject = "Daily Email Automation Summary for " & Format(Date, "mmmm d") & DaySuffix(Day(Date))
        .Body = bodyText
        .Send
    End With
    
    ' Clear the log for the next day
    Set MovedEmails = Nothing

End Sub



'=============================
' Helper Function: Day Suffix
'=============================
' Returns correct ordinal suffix for a day (1st, 2nd, 3rd, 4th, etc.)
Function DaySuffix(d As Integer) As String
    Select Case d Mod 10
        Case 1
            If d = 11 Then
                DaySuffix = "th"
            Else
                DaySuffix = "st"
            End If
        Case 2
            If d = 12 Then
                DaySuffix = "th"
            Else
                DaySuffix = "nd"
            End If
        Case 3
            If d = 13 Then
                DaySuffix = "th"
            Else
                DaySuffix = "rd"
            End If
        Case Else
            DaySuffix = "th"
    End Select
End Function
